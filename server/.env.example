# App
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/blogsphere

# Auth
JWT_SECRET=replace-with-64-char-random-string
JWT_REFRESH_SECRET=replace-with-different-64-char-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Google Gemini (Free Tier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MODEL_PRO=gemini-1.5-pro
GEMINI_RATE_LIMIT_PER_MIN=15
GEMINI_MAX_RETRIES=4

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=BlogSphere AI <no-reply@blogsphere.ai>

# Redis (optional, falls back to memory)
REDIS_URL=

# Security
BCRYPT_SALT_ROUNDS=12
ACCOUNT_LOCK_THRESHOLD=5
ACCOUNT_LOCK_TIME_MIN=15
